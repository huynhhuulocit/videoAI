# Copy this file to deploy/cloudflare-tunnel/.env and update HOSTNAME before running.

# Named Cloudflare Tunnel. Reused if it already exists.
TUNNEL_NAME=videoai-local

# Fixed hostname already managed by Cloudflare DNS, for example videoai.example.com.
HOSTNAME=videoai.example.com

# Public origin used by VideoAI auth and API CORS.
WEB_ORIGIN=https://videoai.example.com

# Required to encrypt/decrypt provider API keys saved in Admin > AI Config.
AI_CONFIG_ENCRYPTION_KEY=change-me-provider-key-encryption-secret

# Local services started by start-project.ps1.
WEB_LOCAL_URL=http://localhost:3000
API_LOCAL_URL=http://localhost:4000

# 1 = start local VideoAI before the tunnel. 0 = assume local app is already running.
START_LOCAL_APP=1

# Outer app-level protection. Keep Cloudflare Access enabled too.
SITE_GATE_ENABLED=true
SITE_GATE_USERNAME=videoai
SITE_GATE_PASSWORD=change-me-site-gate-password
SITE_GATE_SECRET=change-me-site-gate-secret

# Optional Chrome Web Store AI Handoff extension integration.
NEXT_PUBLIC_AI_HANDOFF_ENABLED=false
NEXT_PUBLIC_AI_HANDOFF_EXTENSION_ID=
NEXT_PUBLIC_AI_HANDOFF_EXTENSION_URL=
AI_HANDOFF_PROVIDER=google-flow-veo
AI_HANDOFF_TARGET_URL=https://labs.google/fx/tools/flow/project/5a83ae13-0d06-48fb-a993-b092c7395df4
