# Copy this file to deploy/.env and change every value marked "change-me".

# Caddy site address.
# Use a real domain for HTTPS, for example: videoai.example.com
# Use :80 for IP-only testing without HTTPS.
APP_DOMAIN=:80

# Public browser origin.
# Domain example: https://videoai.example.com
# IP-only example: http://YOUR_SERVER_IP
PUBLIC_WEB_ORIGIN=http://YOUR_SERVER_IP

# Leave empty when Caddy proxies /api on the same origin.
# Set to https://api.example.com only if the API is exposed on a separate origin.
NEXT_PUBLIC_API_GATEWAY_URL=

POSTGRES_USER=videoai
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=videoai

NEXTAUTH_SECRET=change-me-nextauth-secret
AI_CONFIG_ENCRYPTION_KEY=change-me-provider-key-encryption-secret

# Optional outer site-wide gate before the VideoAI app login.
# Set SITE_GATE_ENABLED=true before sharing a public test environment.
SITE_GATE_ENABLED=false
SITE_GATE_USERNAME=videoai
SITE_GATE_PASSWORD=change-me-site-gate-password
SITE_GATE_SECRET=change-me-site-gate-secret

# Optional Chrome Web Store AI Handoff extension integration.
NEXT_PUBLIC_AI_HANDOFF_ENABLED=false
NEXT_PUBLIC_AI_HANDOFF_EXTENSION_ID=
NEXT_PUBLIC_AI_HANDOFF_EXTENSION_URL=
AI_HANDOFF_PROVIDER=google-flow-veo
AI_HANDOFF_TARGET_URL=https://labs.google/fx/tools/flow/project/5a83ae13-0d06-48fb-a993-b092c7395df4

# Provider keys are optional here because the admin UI can store encrypted keys.
# Environment keys are used as fallback if the admin config has no saved key.
GEMINI_API_KEY=
OPENAI_API_KEY=
